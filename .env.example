# Kopieren nach .env und an die eigenen Werte anpassen.

# --- Datenbank (lokal via docker compose) ---
POSTGRES_USER=tippkick
POSTGRES_PASSWORD=tippkick
POSTGRES_DB=tippkick
POSTGRES_PORT=5432
DATABASE_URL="postgresql://tippkick:tippkick@localhost:5432/tippkick?schema=public"

# --- Next.js ---
# Zufälliger String: `openssl rand -base64 32`
AUTH_SECRET=change-me-to-a-long-random-secret

# Öffentliche App-URL (für E-Mail-Links etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- E-Mail ---
# Dev: leer lassen -> E-Mails werden nur in der Konsole ausgegeben.
# Prod: SMTP-Daten hinterlegen (z.B. netcup mailserver).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Tippverein <tippspiel@localhost>"

# --- Bootstrap-Admin (wird beim Seed angelegt) ---
ADMIN_EMAIL=admin@tippkick.local
ADMIN_PASSWORD=change-me

# --- Ergebnis-Sync (OpenLigaDB) ---
# Schützt den Cron-Endpoint /api/cron/sync-results (Bearer-Token).
# Zufälliger String: `openssl rand -hex 32`. In Dev leer für `pnpm sync:results`.
CRON_SECRET=
