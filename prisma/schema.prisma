
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Domain-Modelle (Tippspiel) ───────────────────────────────────────────────
// SSOT für Wettbewerbe/Spieltage/Partien/Tipps. Auth-Tabellen unten werden von
// better-auth verwaltet und nicht von Hand verändert.

enum CompetitionKey {
  BL // Bundesliga (1. + 2. Liga zusammen)
  CL // Champions League
  DFB // DFB-Pokal
  EM // Europameisterschaft
  WM // Weltmeisterschaft
}

// Sektion innerhalb eines Bundesliga-Spieltags (1. Liga / 2. Liga).
enum League {
  BL // 1. Bundesliga
  L2 // 2. Bundesliga
}

model Season {
  id           String        @id @default(cuid())
  name         String        @unique // z. B. "25/26"
  createdAt    DateTime      @default(now())
  competitions Competition[]
}

model Competition {
  id             String      @id @default(cuid())
  seasonId       String
  season         Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  key            CompetitionKey
  name           String // z. B. "Bundesliga (1. + 2. Liga)"
  sortOrder      Int
  sourceShortcuts String[] // OpenLigaDB leagueShortcuts, z. B. ["bl1","bl2"]
  createdAt      DateTime    @default(now())
  matchdays      Matchday[]

  @@unique([seasonId, key])
  @@index([seasonId])
}

/**
 * Eine Tipprunde des Vereins (entspricht 1.TT … 34.TT). Für Bundesliga kann
 * sie 1–2 Liga-Sektionen enthalten (BL-Spieltag N, L2-Spieltag M, …), deren
 * Liga-Matchday-Nummern verschieden sind und Versatz aufweisen können (z. B.
 * TT 1 = nur L2 1+2, kein BL; TT 16 = nur BL 15+16, kein L2).
 */
model Matchday {
  id            String   @id @default(cuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  number        Int      // Tipptag-Nummer (1..34), fortlaufend im Wettbewerb pro Saison
  startDate     DateTime // = MIN(kickoff) aller Sektionen
  endDate       DateTime // = MAX(kickoff) aller Sektionen
  deadlineAt    DateTime // Tipp-Deadline, i. d. R. 1 Min vor frühestem Anstoß
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sections      MatchdaySection[]

  @@unique([competitionId, number])
  @@index([competitionId])
}

/** Eine Liga-Spieltag-Runde innerhalb einer Tipprunde (z. B. "2. Liga · 1. Spieltag"). */
model MatchdaySection {
  id         String   @id @default(cuid())
  matchdayId String
  matchday   Matchday @relation(fields: [matchdayId], references: [id], onDelete: Cascade)
  league     League?  // null für Nicht-Bundesliga-Wettbewerbe (CL/DFB/EM/WM)
  number     Int      // Liga-Matchday-Nummer INNERHALB dieser Liga (1..34 für BL/L2)
  fixtures   Fixture[]

  @@unique([matchdayId, league, number])
  @@index([matchdayId])
}

model Fixture {
  id        String          @id @default(cuid())
  sectionId String
  section   MatchdaySection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  league    League?         // redundant zu section.league (schnelles Filtern ohne JOIN)
  kickoff   DateTime
  homeTeam  String
  awayTeam  String
  sortOrder Int             // Reihenfolge innerhalb der Sektion
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tips      Tip[]

  @@index([sectionId])
  @@index([sectionId, league])
}

model Tip {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fixtureId  String
  fixture    Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  homeGoals  Int
  awayGoals  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Ein Tipper pro Partie genau ein Tipp (SSOT-Constraint).
  @@unique([userId, fixtureId])
  @@index([fixtureId])
}

model User {
  id               String      @id
  name             String
  email            String
  emailVerified    Boolean     @default(false)
  image            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  twoFactorEnabled Boolean?    @default(false)
  role             String?
  banned           Boolean?    @default(false)
  banReason        String?
  banExpires       DateTime?
  sessions         Session[]
  accounts         Account[]
  twofactors       TwoFactor[]
  tips             Tip[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id                      String    @id
  secret                  String
  backupCodes             String
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified                Boolean?  @default(true)
  failedVerificationCount Int?      @default(0)
  lockedUntil             DateTime?

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}
