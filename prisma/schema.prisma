
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Domain-Modelle (Tippspiel) ───────────────────────────────────────────────
// SSOT für Wettbewerbe/Spieltage/Partien/Tipps. Auth-Tabellen unten werden von
// better-auth verwaltet und nicht von Hand verändert.

enum CompetitionKey {
  BL // 1. Bundesliga
  L2 // 2. Bundesliga
  CL // Champions League
  DFB // DFB-Pokal
  EM // Europameisterschaft
  WM // Weltmeisterschaft
}

model Season {
  id           String        @id @default(cuid())
  name         String        @unique // z. B. "25/26"
  createdAt    DateTime      @default(now())
  competitions Competition[]
}

model Competition {
  id             String      @id @default(cuid())
  seasonId       String
  season         Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  key            CompetitionKey
  name           String // z. B. "1. Bundesliga"
  sortOrder      Int
  sourceShortcut String? // OpenLigaDB leagueShortcut, z. B. "bl1"
  createdAt      DateTime    @default(now())
  matchdays      Matchday[]

  @@unique([seasonId, key])
  @@index([seasonId])
}

model Matchday {
  id            String       @id @default(cuid())
  competitionId String
  competition   Competition  @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  number        Int // z. B. 34
  startDate     DateTime
  endDate       DateTime
  deadlineAt    DateTime // Tipp-Deadline, i. d. R. Freitag 19:00
  isActive      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  fixtures      Fixture[]

  @@unique([competitionId, number])
  @@index([competitionId])
}

model Fixture {
  id         String   @id @default(cuid())
  matchdayId String
  matchday   Matchday @relation(fields: [matchdayId], references: [id], onDelete: Cascade)
  kickoff    DateTime
  homeTeam   String
  awayTeam   String
  sortOrder  Int // Reihenfolge innerhalb des Spieltags
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tips       Tip[]

  @@index([matchdayId])
}

model Tip {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fixtureId  String
  fixture    Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  homeGoals  Int
  awayGoals  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Ein Tipper pro Partie genau ein Tipp (SSOT-Constraint).
  @@unique([userId, fixtureId])
  @@index([fixtureId])
}

model User {
  id               String      @id
  name             String
  email            String
  emailVerified    Boolean     @default(false)
  image            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  twoFactorEnabled Boolean?    @default(false)
  role             String?
  banned           Boolean?    @default(false)
  banReason        String?
  banExpires       DateTime?
  sessions         Session[]
  accounts         Account[]
  twofactors       TwoFactor[]
  tips             Tip[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id                      String    @id
  secret                  String
  backupCodes             String
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified                Boolean?  @default(true)
  failedVerificationCount Int?      @default(0)
  lockedUntil             DateTime?

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}
