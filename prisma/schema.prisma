generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Domain-Modelle (Tippspiel) ───────────────────────────────────────────────
// SSOT für Wettbewerbe/Spieltage/Partien/Tipps. Auth-Tabellen unten werden von
// better-auth verwaltet und nicht von Hand verändert.

enum CompetitionKey {
  BL // Bundesliga (1. + 2. Liga zusammen)
  CL // Champions League
  DFB // DFB-Pokal
  EM // Europameisterschaft
  WM // Weltmeisterschaft
}

// Sektion innerhalb eines Bundesliga-Spieltags (1. Liga / 2. Liga).
enum League {
  BL // 1. Bundesliga
  L2 // 2. Bundesliga
}

/**
 * Spiel-Status (verlässlich aus OpenLigaDB: SCHEDULED + FINISHED; Rest manuell).
 */
enum FixtureStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELLED
  POSTPONED
}

/**
 * Herkunft eines Ergebnis-Eintrags. MANUAL gewinnt – Re-Sync überschreibt ihn nicht.
 */
enum ResultSource {
  NONE // kein Ergebnis
  SYNC // von OpenLigaDB übernommen
  MANUAL // von der Tippleitung gesetzt
}

model Season {
  id           String        @id @default(cuid())
  name         String        @unique // z. B. "25/26"
  createdAt    DateTime      @default(now())
  competitions Competition[]
}

model Competition {
  id              String            @id @default(cuid())
  seasonId        String
  season          Season            @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  key             CompetitionKey
  name            String // z. B. "Bundesliga (1. + 2. Liga)"
  sortOrder       Int
  sourceShortcuts String[] // OpenLigaDB leagueShortcuts, z. B. ["bl1","bl2"]
  createdAt       DateTime          @default(now())
  matchdays       Matchday[]
  sections        MatchdaySection[]

  @@unique([seasonId, key])
  @@index([seasonId])
}

/**
 * Eine Tipprunde des Vereins (entspricht 1.TT … 34.TT). Für Bundesliga kann
 * sie 1–2 Liga-Sektionen enthalten (BL-Spieltag N, L2-Spieltag M, …), deren
 * Liga-Matchday-Nummern verschieden sind und Versatz aufweisen können (z. B.
 * TT 1 = nur L2 1+2, kein BL; TT 16 = nur BL 15+16, kein L2).
 */
model Matchday {
  id             String            @id @default(cuid())
  competitionId  String
  competition    Competition       @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  number         Int // Tipptag-Nummer (1..34), fortlaufend im Wettbewerb pro Saison
  startDate      DateTime // = MIN(kickoff) aller Sektionen
  endDate        DateTime // = MAX(kickoff) aller Sektionen
  deadlineAt     DateTime // Tipp-Deadline, i. d. R. 1 Min vor frühestem Anstoß
  deadlineManual Boolean           @default(false) // true: recalcMatchdaySpan überschreibt die Deadline nicht
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  sections       MatchdaySection[]

  @@unique([competitionId, number])
  @@index([competitionId])
}

/**
 * Kanonischer Spieltag (Import-Baustein aus OpenLigaDB), z. B. "2. Liga · 1. Spieltag".
 * Unabhängig vom Tipptag: matchdayId ist optional (null = noch keinem Tipptag zugeordnet).
 * Ein Spieltag wird genau einmal getippt → gehört zu 0..1 Tipptagen. onDelete: SetNull
 * bewirkt, dass beim Löschen eines Tipptags der Spieltag in den Pool zurückwandert statt
 * gelöscht zu werden.
 */
model MatchdaySection {
  id             String      @id @default(cuid())
  competitionId  String
  competition    Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  matchdayId     String?
  matchday       Matchday?   @relation(fields: [matchdayId], references: [id], onDelete: SetNull)
  league         League? // null für Nicht-Bundesliga-Wettbewerbe (CL/DFB/EM/WM)
  number         Int // Liga-Spieltag-Nummer INNERHALB dieser Liga (1..34 für BL/L2) = OpenLigaDB groupOrderId
  startDate      DateTime // = MIN(kickoff) der Partien
  endDate        DateTime // = MAX(kickoff) der Partien
  sourceShortcut String? // OpenLigaDB-Shortcut (bl1/bl2/cl/...), falls per Import angelegt
  fixtures       Fixture[]

  // Kanonische Identität pro Wettbewerb. Hinweis (Prisma 7): nullable Composite-Keys sind
  // nicht typsicher → upsertSection nutzt findFirst-before-create. Für league=null (CL/DFB)
  // ist die Eindeutigkeit durch NULL-Semantik in PG nur App-seitig durchgesetzt.
  @@unique([competitionId, league, number])
  @@index([competitionId])
  @@index([matchdayId])
}

model Fixture {
  id           String          @id @default(cuid())
  sectionId    String
  section      MatchdaySection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  league       League? // redundant zu section.league (schnelles Filtern ohne JOIN)
  kickoff      DateTime
  homeTeam     String
  awayTeam     String
  sortOrder    Int // Reihenfolge innerhalb der Sektion
  externalId   String? // OpenLigaDB matchID — Schlüssel für verlässlichen Ergebnis-Sync
  // Ergebnis (leer bis gesynct/manuell gepflegt)
  homeGoals    Int? // Endergebnis Heim
  awayGoals    Int? // Endergebnis Gast
  htHomeGoals  Int? // Halbzeit Heim
  htAwayGoals  Int? // Halbzeit Gast
  status       FixtureStatus   @default(SCHEDULED)
  resultSource ResultSource    @default(NONE) // MANUAL gewinnt – Re-Sync überschreibt nicht
  syncedAt     DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tips         Tip[]

  @@index([sectionId])
  @@index([sectionId, league])
  @@index([externalId])
}

model Tip {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fixtureId String
  fixture   Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  homeGoals Int
  awayGoals Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ein Tipper pro Partie genau ein Tipp (SSOT-Constraint).
  @@unique([userId, fixtureId])
  @@index([fixtureId])
}

model User {
  id               String      @id
  name             String
  email            String
  emailVerified    Boolean     @default(false)
  image            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  twoFactorEnabled Boolean?    @default(false)
  role             String?
  banned           Boolean?    @default(false)
  banReason        String?
  banExpires       DateTime?
  sessions         Session[]
  accounts         Account[]
  twofactors       TwoFactor[]
  tips             Tip[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id                      String    @id
  secret                  String
  backupCodes             String
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified                Boolean?  @default(true)
  failedVerificationCount Int?      @default(0)
  lockedUntil             DateTime?

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}
